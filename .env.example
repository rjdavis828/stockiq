# Database
DATABASE_URL=postgresql+asyncpg://stock:password@localhost:5432/stockdb
DATABASE_URL_SYNC=postgresql://stock:password@localhost:5432/stockdb

# Redis
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=60

# Auth
SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Data Providers
POLYGON_API_KEY=your_polygon_key
ALPHA_VANTAGE_API_KEY=your_av_key
FINNHUB_API_KEY=your_finnhub_key

# yfinance / Finnhub tuning
YFINANCE_CHUNK_SIZE=100
YFINANCE_CHUNK_SLEEP=1.5
FINNHUB_HOTLIST_MAX=50
WS_STALE_THRESHOLD_S=90

# Ingestion
INGEST_UNIVERSE=SP500
BACKFILL_YEARS=5
INTRADAY_TIMEFRAMES=1m,5m,15m,1h
INTRADAY_POLL_CONCURRENCY=20

# Scanner
MAX_SCAN_UNIVERSE_SIZE=5000
SCANNER_CACHE_TTL=300

# Frontend (Vite)
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_WS_BASE_URL=ws://localhost:8000/ws
